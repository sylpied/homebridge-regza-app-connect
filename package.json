{
  "name": "homebridge-regza-app-connect",
  "version": "0.4.0",
  "description": "Homebridge dynamic platform plugin for controlling REGZA TVs via REGZA App Connect.",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "docs",
    "tsconfig.json",
    "eslint.config.mjs",
    "config.schema.json",
    "README.md",
    "README.ja.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "homebridge-plugin",
    "homebridge",
    "regza",
    "toshiba",
    "tv",
    "homekit"
  ],
  "engines": {
    "node": ">=22.0.0",
    "homebridge": ">=1.8.0"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rimraf dist",
    "lint": "eslint src/**/*.ts",
    "prepack": "npm run clean && npm run build",
    "publish:dry-run": "npm publish --dry-run"
  },
  "dependencies": {
    "wake_on_lan": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/node": "^22.13.14",
    "eslint": "^9.31.0",
    "homebridge": "^1.11.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.36.0"
  },
  "homebridge": {
    "pluginAlias": "RegzaAppConnect",
    "pluginType": "platform"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sylpied/homebridge-regza-app-connect.git"
  },
  "bugs": {
    "url": "https://github.com/sylpied/homebridge-regza-app-connect/issues"
  },
  "homepage": "https://github.com/sylpied/homebridge-regza-app-connect#readme"
}
